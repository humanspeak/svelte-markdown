{
    "name": "docs",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsx ./scripts/fetch-github-stats.ts && vite build",
        "cf-typegen": "wrangler types && mv worker-configuration.d.ts src/",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "deploy": "pnpm run build && wrangler deploy",
        "dev": "vite dev",
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint .",
        "lint:fix": "pnpm run format && eslint . --fix",
        "preview": "vite preview"
    },
    "dependencies": {
        "@fontsource-variable/inter": "^5.2.8",
        "@fontsource-variable/jetbrains-mono": "^5.2.8",
        "@humanspeak/docs-kit": "github:humanspeak/docs-kit#2026.6.2",
        "@humanspeak/svelte-markdown": "workspace:*",
        "katex": "^0.17.0",
        "marked-code-format": "^1.1.6",
        "mermaid": "^11.15.0",
        "prettier": "^3.8.3",
        "runed": "^0.37.1"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260531.1",
        "@eslint/compat": "^2.1.0",
        "@eslint/js": "^10.0.1",
        "@humanspeak/svelte-motion": "^0.6.2",
        "@icons-pack/svelte-simple-icons": "^7.2.0",
        "@lucide/svelte": "^1.17.0",
        "@sveltejs/adapter-cloudflare": "^7.2.8",
        "@sveltejs/kit": "^2.61.1",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/postcss": "^4.3.0",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.3.0",
        "@types/katex": "^0.16.8",
        "@typescript-eslint/eslint-plugin": "^8.60.0",
        "@typescript-eslint/parser": "^8.60.0",
        "autoprefixer": "^10.5.0",
        "chokidar-cli": "^3.0.0",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-svelte": "3.19.0",
        "globals": "^17.6.0",
        "mdsvex": "^0.12.7",
        "mode-watcher": "^1.1.0",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-sort-json": "^4.2.0",
        "prettier-plugin-svelte": "^4.0.1",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "shiki": "^4.1.0",
        "svelte": "^5.56.0",
        "svelte-check": "^4.4.8",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vite": "^8.0.14",
        "wrangler": "^4.95.0"
    },
    "volta": {
        "node": "24.15.0"
    }
}
