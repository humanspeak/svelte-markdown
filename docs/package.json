{
    "name": "docs",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsx ./scripts/fetch-github-stats.ts && vite build",
        "build:indexnow": "tsx ./scripts/fetch-github-stats.ts && vite build --mode indexnow",
        "cf-typegen": "wrangler types && mv worker-configuration.d.ts src/",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "deploy": "pnpm run build:indexnow && wrangler deploy",
        "dev": "vite dev",
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint .",
        "lint:fix": "pnpm run format && eslint . --fix",
        "preview": "vite preview"
    },
    "dependencies": {
        "@fontsource-variable/inter": "^5.2.8",
        "@fontsource-variable/jetbrains-mono": "^5.2.8",
        "@humanspeak/docs-kit": "github:humanspeak/docs-kit#2026.6.16",
        "@humanspeak/svelte-markdown": "workspace:*",
        "katex": "^0.17.0",
        "marked-code-format": "^1.1.6",
        "mermaid": "^11.16.0",
        "prettier": "^3.9.4",
        "runed": "^0.37.1"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^5.20260705.1",
        "@eslint/compat": "^2.1.0",
        "@eslint/js": "^10.0.1",
        "@humanspeak/svelte-motion": "^0.7.13",
        "@icons-pack/svelte-simple-icons": "^7.2.0",
        "@lucide/svelte": "^1.23.0",
        "@sveltejs/adapter-cloudflare": "^7.2.9",
        "@sveltejs/kit": "^2.69.1",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/postcss": "^4.3.2",
        "@tailwindcss/typography": "^0.5.20",
        "@tailwindcss/vite": "^4.3.2",
        "@types/katex": "^0.16.8",
        "@typescript-eslint/eslint-plugin": "^8.62.1",
        "@typescript-eslint/parser": "^8.62.1",
        "autoprefixer": "^10.5.2",
        "chokidar-cli": "^3.0.0",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-svelte": "3.20.0",
        "globals": "^17.7.0",
        "mdsvex": "^0.12.7",
        "mode-watcher": "^1.1.0",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-sort-json": "^4.2.0",
        "prettier-plugin-svelte": "^4.1.1",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "shiki": "^4.3.1",
        "svelte": "^5.56.4",
        "svelte-check": "^4.7.1",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.2",
        "tsx": "^4.23.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.1",
        "vite": "^8.1.3",
        "wrangler": "^4.107.0"
    },
    "volta": {
        "node": "24.15.0"
    }
}
